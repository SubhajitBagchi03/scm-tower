# Supply Chain Control Tower Environment Configuration

# ── LLM Provider (Groq) ──
# Required for all agentic reasoning and AI features
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Database Configuration (SQLite) ──
# Local SQLite database for persisting inventory, suppliers, and shipments
DATABASE_URL=sqlite+aiosqlite:///./scm_db.db

# ── Business Rules Overrides (Optional) ──
# You can override config.json values here via environment variables:
# SERVICE_LEVEL_Z_SCORE=1.645
# ORDERING_COST=50.0
# HOLDING_COST=5.0
# SUPPLIER_LOW_RELIABILITY_THRESHOLD=0.60
# CONFLICT_AUTO_APPLY_THRESHOLD=0.85
